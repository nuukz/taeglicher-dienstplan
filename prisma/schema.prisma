generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// Dienstplan-Modul – Modular aufgebaut für ShiftHero-Integration
// ============================================================

enum Rolle {
  SYSOP
  ADMIN
  KOLLEGE
}

enum Beschaeftigung {
  BEAMTER
  ANGESTELLTER
  AZUBI
}

enum SchichtTyp {
  TAG
  NACHT
}

enum AbwesenheitsGrund {
  KRANK
  URLAUB
  FORTBILDUNG
  FREI
  SONSTIGES
}

// --- Abteilung ---
model Abteilung {
  id        String   @id @default(cuid())
  name      String   @unique // 1, 2, 3
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users       User[]
  dienstplaene Dienstplan[]

  @@map("dp_abteilung")
}

// --- Qualifikation ---
model Qualifikation {
  id      String @id @default(cuid())
  kuerzel String @unique // "NotSan", "RS", "AGT", etc.
  name    String         // "Notfallsanitäter", "Rettungssanitäter", etc.
  farbe   String @default("#6b7280") // Hex-Farbe für Badge

  users                 UserQualifikation[]
  positionsAnforderungen PositionQualifikation[]

  @@map("dp_qualifikation")
}

// --- UserQualifikation (Join Table) ---
model UserQualifikation {
  userId          String
  qualifikationId String

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  qualifikation Qualifikation @relation(fields: [qualifikationId], references: [id], onDelete: Cascade)

  @@id([userId, qualifikationId])
  @@map("dp_user_qualifikation")
}

// --- User ---
model User {
  id             String        @id @default(cuid())
  email          String        @unique
  passwortHash   String
  vorname        String
  nachname       String
  rolle          Rolle         @default(KOLLEGE)
  beschaeftigung Beschaeftigung
  aktiv          Boolean       @default(true)
  abteilungId    String
  // Tagesvertretung: wenn gesetzt, ist dieser User eine Aushilfe nur fuer dieses
  // Datum und erscheint ausschliesslich an diesem Tag in der Verfuegbarkeitsliste.
  vertretungFuerDatum DateTime? @db.Date
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  abteilung         Abteilung              @relation(fields: [abteilungId], references: [id])
  zuweisungen       Zuweisung[]
  pushSubscriptions PushSubscription[]
  qualifikationen   UserQualifikation[]
  abwesenheiten     Abwesenheit[]
  aenderungen       DienstplanAenderung[]

  @@map("dp_user")
}

// --- Abwesenheit ---
model Abwesenheit {
  id        String            @id @default(cuid())
  userId    String
  datum     DateTime          @db.Date
  schicht   SchichtTyp?       // null = ganzer Tag
  grund     AbwesenheitsGrund
  notiz     String?
  createdAt DateTime          @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, datum, schicht])
  @@map("dp_abwesenheit")
}

// --- Fahrzeug ---
model Fahrzeug {
  id        String   @id @default(cuid())
  name      String   @unique // HLF, DL, ELW, RTW1, RTW2
  typ       String   // Löschfahrzeug, Drehleiter, Einsatzleitwagen, Rettungswagen
  aktiv     Boolean  @default(true)
  reihenfolge Int    @default(0) // Sortierung in der Anzeige
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Mit-Besetzung: dieses Fahrzeug wird von parent mitbesetzt und spiegelt
  // dessen Mannschaft (z.B. GW MANV <- HLF, GW <- RTW Kaufmann).
  parentFahrzeugId String?
  parent           Fahrzeug?  @relation("MitBesetzung", fields: [parentFahrzeugId], references: [id], onDelete: SetNull)
  kinder           Fahrzeug[] @relation("MitBesetzung")

  positionen     FahrzeugPosition[]
  tagesFahrzeuge TagesFahrzeug[]
  dienstzeiten   FahrzeugDienstzeit[]

  @@map("dp_fahrzeug")
}

// --- FahrzeugDienstzeit ---
// Standard-Wochenvorlage pro Fahrzeug: an welchen Wochentagen + Schichten ist das
// Fahrzeug normalerweise im Dienst. Global (SYSOP). Wird beim Anlegen eines
// Dienstplans angewendet, um nicht-im-Dienst-Fahrzeuge als inaktiv vorzubelegen.
model FahrzeugDienstzeit {
  id         String     @id @default(cuid())
  fahrzeugId String
  wochentag  Int        // 0 = Montag ... 6 = Sonntag
  schicht    SchichtTyp // TAG | NACHT
  imDienst   Boolean    @default(true)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  fahrzeug Fahrzeug @relation(fields: [fahrzeugId], references: [id], onDelete: Cascade)

  @@unique([fahrzeugId, wochentag, schicht])
  @@map("dp_fahrzeug_dienstzeit")
}

// --- FahrzeugPosition ---
model FahrzeugPosition {
  id          String   @id @default(cuid())
  name        String   // Maschinist, Fahrzeugführer, Angriffstrupp, etc.
  fahrzeugId  String
  reihenfolge Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  fahrzeug               Fahrzeug                @relation(fields: [fahrzeugId], references: [id], onDelete: Cascade)
  zuweisungen            Zuweisung[]
  requiredQualifikationen PositionQualifikation[]

  @@unique([fahrzeugId, name])
  @@map("dp_fahrzeug_position")
}

// --- PositionQualifikation (Join: Position ↔ erforderliche Qualifikation) ---
model PositionQualifikation {
  positionId      String
  qualifikationId String

  position      FahrzeugPosition @relation(fields: [positionId], references: [id], onDelete: Cascade)
  qualifikation Qualifikation    @relation(fields: [qualifikationId], references: [id], onDelete: Cascade)

  @@id([positionId, qualifikationId])
  @@map("dp_position_qualifikation")
}

// --- Sonderfunktion ---
model Sonderfunktion {
  id        String   @id @default(cuid())
  name      String   @unique // Koch, Tagesdienst, Schirmmeister, etc.
  aktiv     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  zuweisungen Zuweisung[]

  @@map("dp_sonderfunktion")
}

// --- Dienstplan ---
model Dienstplan {
  id            String    @id @default(cuid())
  datum         DateTime  @db.Date
  schicht       SchichtTyp
  abteilungId   String
  veroeffentlicht Boolean @default(false)
  version       Int       @default(0)    // 0 = Entwurf, 1+ = veröffentlichte Version
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  abteilung      Abteilung           @relation(fields: [abteilungId], references: [id])
  zuweisungen    Zuweisung[]
  tagesFahrzeuge TagesFahrzeug[]
  aenderungen    DienstplanAenderung[]

  @@unique([datum, schicht, abteilungId])
  @@map("dp_dienstplan")
}

// --- Zuweisung ---
model Zuweisung {
  id               String  @id @default(cuid())
  dienstplanId     String
  userId           String
  fahrzeugPositionId String
  sonderfunktionId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  dienstplan       Dienstplan       @relation(fields: [dienstplanId], references: [id], onDelete: Cascade)
  user             User             @relation(fields: [userId], references: [id])
  fahrzeugPosition FahrzeugPosition @relation(fields: [fahrzeugPositionId], references: [id])
  sonderfunktion   Sonderfunktion?  @relation(fields: [sonderfunktionId], references: [id])

  @@unique([dienstplanId, fahrzeugPositionId]) // Position nur einmal besetzt
  @@unique([dienstplanId, userId])             // Person nur einmal pro Schicht
  @@map("dp_zuweisung")
}

// --- TagesFahrzeug (Override: Fahrzeug tageweise an/aus) ---
model TagesFahrzeug {
  id           String   @id @default(cuid())
  dienstplanId String
  fahrzeugId   String
  aktiv        Boolean  @default(false) // false = Fahrzeug ist an diesem Tag NICHT verfügbar
  createdAt    DateTime @default(now())

  dienstplan Dienstplan @relation(fields: [dienstplanId], references: [id], onDelete: Cascade)
  fahrzeug   Fahrzeug   @relation(fields: [fahrzeugId], references: [id])

  @@unique([dienstplanId, fahrzeugId])
  @@map("dp_tages_fahrzeug")
}

// --- DienstplanAenderung (Changelog für Push) ---
model DienstplanAenderung {
  id           String   @id @default(cuid())
  dienstplanId String
  version      Int      @default(0)    // Welche Version wurde veröffentlicht
  userId       String?                 // Wer hat veröffentlicht
  beschreibung String                  // "Veröffentlicht", "Aktualisiert" etc.
  snapshot     String?                 // JSON: Zuweisungen zum Zeitpunkt der Veröffentlichung
  createdAt    DateTime @default(now())

  dienstplan Dienstplan @relation(fields: [dienstplanId], references: [id], onDelete: Cascade)
  user       User?      @relation(fields: [userId], references: [id])

  @@map("dp_dienstplan_aenderung")
}

// --- PushSubscription ---
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("dp_push_subscription")
}

// --- SchichtKonfiguration ---
model SchichtKonfiguration {
  id         String    @id @default(cuid())
  schicht    SchichtTyp @unique
  startZeit  String    // "07:00"
  endZeit    String    // "19:00"
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@map("dp_schicht_konfiguration")
}
